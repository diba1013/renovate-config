{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:best-practices",
		":assignee(diba1013)",
		":labels(dependencies)",
		":rebaseStalePrs",
		":semanticCommits",
		":semanticCommitScope(deps)",
		"npm:unpublishSafe"
	],
	"packageRules": [
		{
			"description": "Automatically merge development / production dependencies up to minor.",
			"matchDepTypes": ["devDependencies", "production", "packageManager", "engines", "action"],
			"extends": [":automergeMinor", ":automergeDigest"]
		},
		{
			"description": "Automatically merge lockfile maintenance.",
			"matchUpdateTypes": ["lockFileMaintenance"],
			"extends": [":automergeAll"]
		},
		{
			"description": "Automatically merge node updates up to major.",
			"matchPackageNames": ["node"],
			"extends": [":automergeMajor"]
		}
	]
}
